{
  "name": "hello-world-check-run-app",
  "version": "1.0.0",
  "description": "A GitHub App that creates hello world check runs",
  "main": "dist/index.js",
  "scripts": {
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "build": "tsc",
    "start": "node -r dotenv/config dist/index.js",
    "dev": "tsc --watch & node --watch dist/index.js",
    "deploy": "pnpm run build && pnpm run start"
  },
  "keywords": [
    "github",
    "app",
    "webhook",
    "checks"
  ],
  "author": "Yasunori MAHATA",
  "packageManager": "pnpm@10.12.1",
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "happy-dom": "^18.0.1",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4",
    "wrangler": "^4.21.2"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.4",
    "@octokit/app": "^16.0.1",
    "@octokit/auth-app": "^8.0.1",
    "@octokit/rest": "^22.0.0",
    "@octokit/webhooks": "^14.0.2",
    "dotenv": "^16.5.0",
    "hono": "^4.8.3",
    "install": "^0.13.0",
    "jsonwebtoken": "^9.0.2",
    "npm": "^11.4.2"
  }
}
