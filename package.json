{
	"name": "hello-world-check-run-app",
	"version": "1.0.0",
	"description": "A GitHub App that creates hello world check runs",
	"main": "dist/index.js",
	"scripts": {
		"test": "vitest",
		"test:run": "vitest run --logHeapUsage",
		"test:coverage": "vitest run --coverage",
		"test:ui": "vitest --ui",
		"build": "tsc",
		"cf:dev": "wrangler dev",
		"cf:deploy": "pnpm run build && wrangler deploy",
		"cf:tail": "wrangler tail",
		"lint": "biome check ./",
		"lint:fix": "biome check ./ --write --unsafe --diagnostic-level=error --files-ignore-unknown=true"
	},
	"keywords": [
		"github",
		"app",
		"webhook",
		"checks"
	],
	"author": "Yasunori MAHATA",
	"packageManager": "pnpm@10.12.1",
	"devDependencies": {
		"@biomejs/biome": "^2.0.6",
		"@cloudflare/workers-types": "^4.20241127.0",
		"@types/jsonwebtoken": "^9.0.10",
		"@types/node": "^24.1.0",
		"@vitest/coverage-v8": "^3.2.4",
		"@vitest/ui": "^3.2.4",
		"typescript": "^5.8.3",
		"vitest": "^3.2.4",
		"wrangler": "^4.23.0"
	},
	"dependencies": {
		"@octokit/app": "^16.0.1",
		"@octokit/auth-app": "^8.0.1",
		"@octokit/rest": "^22.0.0",
		"@octokit/webhooks": "^14.1.0",
		"hono": "^4.8.3",
		"jsonwebtoken": "^9.0.2"
	}
}
